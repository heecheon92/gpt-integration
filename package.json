{
  "name": "gpt-integration",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm lint && next dev --inspect",
    "dev:secure": "pnpm lint && next dev --inspect --experimental-https",
    "profile": "ANALYZE=true pnpm build",
    "build": "next build",
    "start": "next start",
    "lint": "pnpm typecheck && biome lint",
    "lint:fix": "pnpm typecheck && biome lint --fix",
    "pret": "biome format",
    "pret:fix": "biome format --write",
    "biome": "pnpm typecheck && biome check . --max-diagnostics=100",
    "biome:fix": "pnpm typecheck && biome check . --write --max-diagnostics=100 && tailwind-lint --auto --fix",
    "biome:summary": "biome check --reporter=summary --max-diagnostics=100",
    "prepare": "husky",
    "postinstall": "pnpm exec prisma generate",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.53",
    "@ai-sdk/react": "3.0.170",
    "@base-ui/react": "^1.4.1",
    "@clerk/nextjs": "^6.11.1",
    "@clerk/themes": "^2.2.16",
    "@hookform/resolvers": "^3.10.0",
    "@pinecone-database/pinecone": "^4.1.0",
    "@tabler/icons-react": "^3.41.1",
    "ai": "^6.0.168",
    "babel-plugin-react-compiler": "^19.0.0-beta-714736e-20250131",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "lucide-react": "^0.475.0",
    "next": "16.2.4",
    "next-themes": "^0.4.4",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-hook-form": "^7.54.2",
    "react-markdown": "^9.0.3",
    "shadcn": "^4.4.0",
    "tailwind-merge": "^3.0.1",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@prisma/client": "^6.3.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^20",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "husky": "^9.1.7",
    "postcss": "^8",
    "prisma": "^6.3.1",
    "tailwindcss": "^4.2.4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "@clerk/shared",
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "sharp"
    ],
    "overrides": {
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
